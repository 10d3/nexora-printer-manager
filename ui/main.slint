// Nexora POS Printer Manager - Refined UI
// Design System: Minimalist, Professional, Clean
import {
    Button,
    LineEdit,
    ScrollView,
    VerticalBox,
    HorizontalBox,
} from "std-widgets.slint";

// ============================================
// DESIGN TOKENS
// ============================================

// Device structure
export struct Device {
    path: string,
    description: string,
    type: string,
}

// Printer status
export struct PrinterStatus {
    connected: bool,
    device-path: string,
    connection-type: string,
}

// ============================================
// REUSABLE COMPONENTS
// ============================================

// Icon component using SF Symbols style
component Icon inherits Text {
    in property <string> icon;
    in property <length> size: 20px;
    in property <color> icon-color: #64748b;

    text: icon;
    font-size: size;
    color: icon-color;
    horizontal-alignment: center;
    vertical-alignment: center;
}

// Section Title
component SectionTitle inherits Text {
    in property <string> label;

    text: label;
    color: #0f172a;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.5px;
}

// Connection Type Card
component ConnectionCard inherits Rectangle {
    in property <string> icon;
    in property <string> label;
    in property <bool> selected: false;
    in property <bool> disabled: false;

    callback clicked();

    width: 100%;
    height: 56px;
    background: selected ? #0f172a : #ffffff;
    border-radius: 10px;
    border-width: selected ? 0px : 1px;
    border-color: #e2e8f0;

    animate background {
        duration: 150ms;
        easing: ease-out;
    }
    animate border-color {
        duration: 150ms;
        easing: ease-out;
    }

    HorizontalBox {
        padding-left: 16px;
        padding-right: 16px;
        spacing: 12px;

        Icon {
            icon: icon;
            size: 18px;
            icon-color: selected ? #ffffff : #64748b;
            width: 24px;
        }

        Text {
            text: label;
            color: selected ? #ffffff : #0f172a;
            font-size: 14px;
            font-weight: selected ? 600 : 500;
            vertical-alignment: center;
        }

        Rectangle {
            horizontal-stretch: 1;
        }

        if selected: Rectangle {
            width: 20px;
            height: 20px;
            background: #22c55e;
            border-radius: 10px;

            Text {
                text: "✓";
                color: white;
                font-size: 12px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    TouchArea {
        mouse-cursor: disabled ? default : pointer;
        clicked => {
            if !disabled {
                clicked();
            }
        }
    }
}

// Device List Item
component DeviceItem inherits Rectangle {
    in property <string> path;
    in property <string> description;
    in property <string> device-type;
    in property <bool> selected: false;

    callback clicked();

    height: 52px;
    background: selected ? #f0f9ff : #ffffff;
    border-radius: 8px;
    border-width: 1px;
    border-color: selected ? #0ea5e9 : #f1f5f9;

    animate background { duration: 120ms; }
    animate border-color { duration: 120ms; }

    HorizontalBox {
        padding-left: 14px;
        padding-right: 14px;
        spacing: 12px;

        Rectangle {
            width: 32px;
            height: 32px;
            background: selected ? #e0f2fe : #f8fafc;
            border-radius: 8px;

            Text {
                text: device-type == "USB" ? "⌁" : device-type == "Network" ? "◉" : "▣";
                color: selected ? #0284c7 : #94a3b8;
                font-size: 14px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        VerticalBox {
            spacing: 2px;
            alignment: center;

            Text {
                text: path;
                color: #0f172a;
                font-size: 13px;
                font-weight: 500;
            }

            Text {
                text: description;
                color: #94a3b8;
                font-size: 11px;
            }
        }

        Rectangle {
            horizontal-stretch: 1;
        }

        if selected: Rectangle {
            width: 6px;
            height: 6px;
            background: #0ea5e9;
            border-radius: 3px;
        }
    }

    TouchArea {
        mouse-cursor: pointer;
        clicked => {
            clicked();
        }
    }
}

// Primary Button
component PrimaryButton inherits Rectangle {
    in property <string> label;
    in property <bool> disabled: false;
    in property <bool> loading: false;
    in property <color> bg: #0f172a;

    callback clicked();

    height: 44px;
    background: disabled ? #e2e8f0 : bg;
    border-radius: 10px;

    animate background { duration: 150ms; }

    HorizontalBox {
        padding-left: 20px;
        padding-right: 20px;
        spacing: 8px;
        alignment: center;

        if loading: Text {
            text: "◌";
            color: white;
            font-size: 14px;
        }

        Text {
            text: loading ? "Please wait..." : label;
            color: disabled ? #94a3b8 : white;
            font-size: 14px;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    TouchArea {
        mouse-cursor: disabled ? default : pointer;
        clicked => {
            if !disabled && !loading {
                clicked();
            }
        }
    }
}

// Secondary Button
component SecondaryButton inherits Rectangle {
    in property <string> label;
    in property <bool> disabled: false;

    callback clicked();

    height: 44px;
    background: #ffffff;
    border-radius: 10px;
    border-width: 1px;
    border-color: #e2e8f0;

    animate background { duration: 150ms; }
    animate border-color { duration: 150ms; }

    Text {
        text: label;
        color: disabled ? #94a3b8 : #0f172a;
        font-size: 14px;
        font-weight: 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    TouchArea {
        mouse-cursor: disabled ? default : pointer;
        clicked => {
            if !disabled {
                clicked();
            }
        }
    }
}

// Status Badge
component StatusBadge inherits Rectangle {
    in property <bool> active: false;
    in property <string> label;

    width: self.preferred-width;
    height: 28px;
    background: active ? #dcfce7 : #f1f5f9;
    border-radius: 14px;
    padding-left: 12px;
    padding-right: 12px;

    HorizontalBox {
        spacing: 6px;
        alignment: center;

        Rectangle {
            width: 6px;
            height: 6px;
            background: active ? #22c55e : #94a3b8;
            border-radius: 3px;
        }

        Text {
            text: label;
            color: active ? #166534 : #64748b;
            font-size: 12px;
            font-weight: 500;
        }
    }
}



// Toast Notification
component Toast inherits Rectangle {
    in property <string> message;
    in property <string> type: "info"; // success, error, warning, info
    
    property <color> bg-color: type == "success" ? #f0fdf4 : type == "error" ? #fef2f2 : type == "warning" ? #fffbeb : #f0f9ff;
    property <color> border-clr: type == "success" ? #bbf7d0 : type == "error" ? #fecaca : type == "warning" ? #fde68a : #bae6fd;
    property <color> text-clr: type == "success" ? #166534 : type == "error" ? #991b1b : type == "warning" ? #92400e : #0369a1;
    property <string> icon: type == "success" ? "✓" : type == "error" ? "✕" : type == "warning" ? "!" : "i";

    height: 48px;
    background: bg-color;
    border-radius: 10px;
    border-width: 1px;
    border-color: border-clr;

    HorizontalBox {
        padding-left: 14px;
        padding-right: 14px;
        spacing: 10px;

        Rectangle {
            width: 22px;
            height: 22px;
            background: border-clr;
            border-radius: 11px;

            Text {
                text: icon;
                color: text-clr;
                font-size: 11px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Text {
            text: message;
            color: text-clr;
            font-size: 13px;
            font-weight: 500;
            vertical-alignment: center;
        }
    }
}

// ============================================
// MAIN WINDOW
// ============================================

export component MainWindow inherits Window {
    title: "Nexora Printer Manager";
icon: @image-url("../assets/favicon.png");
    preferred-width: 960px;
    preferred-height: 720px;
    min-width: 820px;
    min-height: 600px;
    background: #ffffff;

    // ── Receipt printer callbacks ──
    callback scan-devices();
    callback connect-printer(string, string);
    callback disconnect-printer();
    callback test-print();
    callback save-settings();

    // ── Barcode printer callbacks ──
    callback barcode-connect-printer(string, string, string, int, int, int);
    callback barcode-disconnect-printer();
    callback barcode-test-print();

    // ── Receipt printer properties ──
    in-out property <[Device]> available-devices: [];
    in-out property <bool> is-connected: false;
    in-out property <bool> is-loading: false;
    in-out property <string> status-message: "";
    in-out property <string> selected-connection-type: "USB";
    in-out property <string> selected-device: "";
    in-out property <string> device-filter: "All";

    // ── Barcode printer properties ──
    in-out property <bool> barcode-is-connected: false;
    in-out property <bool> barcode-is-loading: false;
    in-out property <string> barcode-status-message: "";
    in-out property <string> barcode-connection-type: "USB";
    in-out property <string> barcode-device: "";
    in-out property <string> barcode-protocol: "TSPL";
    in-out property <int> barcode-width-mm: 50;
    in-out property <int> barcode-height-mm: 30;
    in-out property <int> barcode-dpi: 203;

    // ── Derived toast types ──
    property <string> toast-type:
        status-message == "" ? "info" :
        (status-message == "✓ Printer connected successfully!" ||
         status-message == "✓ Test page printed successfully!" ||
         status-message == "✓ Settings saved successfully!") ? "success" :
        (status-message == "✗ Print failed: Failed to write to printer") ? "error" : "warning";

    property <string> barcode-toast-type:
        barcode-status-message == "" ? "info" :
        (barcode-status-message == "✓ Barcode printer connected!" ||
         barcode-status-message == "✓ Auto-connected to barcode printer!" ||
         barcode-status-message == "✓ Test label printed successfully!") ? "success" :
        (barcode-status-message == "✗ Connection failed" ||
         barcode-status-message == "✗ Print failed") ? "error" : "warning";

    HorizontalBox {
        padding: 0px;
        spacing: 0px;

        // ========== LEFT SIDEBAR ==========
        Rectangle {
            width: 240px;
            background: #fafafa;
            border-width: 0px;

            VerticalBox {
                padding: 24px;
                spacing: 0px;

                // Logo Area
                VerticalBox {
                    spacing: 4px;
                    padding-bottom: 32px;

                    HorizontalBox {
                        spacing: 10px;

                        Rectangle {
    width: 36px;
    height: 36px;
    background: #0f172a;
    border-radius: 10px;
    Image {
        source: @image-url("../assets/favicon.png");
        width: 24px;
        height: 24px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }
}

                        VerticalBox {
                            spacing: 0px;
                            alignment: center;

                            Text {
                                text: "Nexora";
                                color: #0f172a;
                                font-size: 18px;
                                font-weight: 700;
                            }

                            Text {
                                text: "Printer Manager";
                                color: #64748b;
                                font-size: 11px;
                            }
                        }
                    }
                }

                // Divider
                Rectangle {
                    height: 1px;
                    background: #e2e8f0;
                }

                // Receipt Printer Status
                VerticalBox {
                    padding-top: 20px;
                    padding-bottom: 12px;
                    spacing: 8px;

                    SectionTitle { label: "RECEIPT PRINTER"; }

                    StatusBadge {
                        active: is-connected;
                        label: is-connected ? "Connected" : "Disconnected";
                    }

                    if is-connected: VerticalBox {
                        spacing: 4px;

                        HorizontalBox {
                            Text { text: "Device"; color: #94a3b8; font-size: 11px; width: 48px; }
                            Text { text: selected-device; color: #0f172a; font-size: 11px; font-weight: 500; overflow: elide; }
                        }
                        HorizontalBox {
                            Text { text: "Type"; color: #94a3b8; font-size: 11px; width: 48px; }
                            Text { text: selected-connection-type; color: #0f172a; font-size: 11px; font-weight: 500; }
                        }
                    }
                }

                // Divider
                Rectangle { height: 1px; background: #e2e8f0; }

                // Barcode Printer Status
                VerticalBox {
                    padding-top: 20px;
                    padding-bottom: 12px;
                    spacing: 8px;

                    SectionTitle { label: "BARCODE PRINTER"; }

                    StatusBadge {
                        active: barcode-is-connected;
                        label: barcode-is-connected ? "Connected" : "Disconnected";
                    }

                    if barcode-is-connected: VerticalBox {
                        spacing: 4px;

                        HorizontalBox {
                            Text { text: "Device"; color: #94a3b8; font-size: 11px; width: 48px; }
                            Text { text: barcode-device; color: #0f172a; font-size: 11px; font-weight: 500; overflow: elide; }
                        }
                        HorizontalBox {
                            Text { text: "Proto"; color: #94a3b8; font-size: 11px; width: 48px; }
                            Text { text: barcode-protocol; color: #0f172a; font-size: 11px; font-weight: 500; }
                        }
                    }
                }

                // Divider
                Rectangle { height: 1px; background: #e2e8f0; }

                // Quick Actions
                VerticalBox {
                    padding-top: 20px;
                    spacing: 10px;

                    SectionTitle { label: "QUICK ACTIONS"; }

                    SecondaryButton {
                        label: "Receipt Test";
                        disabled: !is-connected || is-loading;
                        clicked => { test-print(); }
                    }

                    SecondaryButton {
                        label: "Barcode Test";
                        disabled: !barcode-is-connected || barcode-is-loading;
                        clicked => { barcode-test-print(); }
                    }

                    SecondaryButton {
                        label: "Save Settings";
                        disabled: is-loading;
                        clicked => { save-settings(); }
                    }
                }

                // Spacer
                Rectangle { vertical-stretch: 1; }

                // Footer
                VerticalBox {
                    spacing: 4px;
                    Rectangle { height: 1px; background: #e2e8f0; }
                    Text {
                        text: "v1.6.6";
                        color: #cbd5e1;
                        font-size: 11px;
                        horizontal-alignment: center;
                        padding-top: 16px;
                    }
                }
            }
        }

        // ========== MAIN CONTENT ==========
        Rectangle {
            background: #ffffff;

            ScrollView {
                VerticalBox {
                    padding: 40px;
                    padding-top: 48px;
                    spacing: 32px;
                    alignment: start;

                    // Header
                    VerticalBox {
                        spacing: 6px;

                        Text {
                            text: "Printer Setup";
                            color: #0f172a;
                            font-size: 28px;
                            font-weight: 700;
                        }

                        Text {
                            text: "Configure your receipt printer and barcode printer independently";
                            color: #64748b;
                            font-size: 14px;
                        }
                    }

                    // ── RECEIPT PRINTER SECTION ──
                    Rectangle {
                        background: #fafafa;
                        border-radius: 16px;
                        border-width: 1px;
                        border-color: #e2e8f0;

                        VerticalBox {
                            padding: 24px;
                            spacing: 20px;

                            // Section header
                            HorizontalBox {
                                spacing: 10px;
                                alignment: start;

                                Rectangle {
                                    width: 32px;
                                    height: 32px;
                                    background: #0f172a;
                                    border-radius: 8px;
                                    Text {
                                        text: "🧾";
                                        font-size: 16px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                VerticalBox {
                                    spacing: 0px;
                                    alignment: center;
                                    Text {
                                        text: "Receipt Printer";
                                        color: #0f172a;
                                        font-size: 16px;
                                        font-weight: 700;
                                    }
                                    Text {
                                        text: "ESC/POS — USB, Network, or LPT";
                                        color: #94a3b8;
                                        font-size: 12px;
                                    }
                                }

                                Rectangle { horizontal-stretch: 1; }

                                StatusBadge {
                                    active: is-connected;
                                    label: is-connected ? "Online" : "Offline";
                                }
                            }

                    // Connection type row
                            HorizontalBox {
                                spacing: 10px;

                                ConnectionCard {
                                    icon: "⌁"; label: "USB";
                                    selected: selected-connection-type == "USB";
                                    disabled: is-connected;
                                    clicked => { selected-connection-type = "USB"; }
                                }
                                ConnectionCard {
                                    icon: "◉"; label: "Network";
                                    selected: selected-connection-type == "Network";
                                    disabled: is-connected;
                                    clicked => { selected-connection-type = "Network"; }
                                }
                                ConnectionCard {
                                    icon: "▣"; label: "LPT";
                                    selected: selected-connection-type == "LPT";
                                    disabled: is-connected;
                                    clicked => { selected-connection-type = "LPT"; }
                                }
                            }

                            // Device input + scan
                            HorizontalBox {
                                spacing: 10px;

                                Rectangle {
                                    height: 44px;
                                    horizontal-stretch: 1;
                                    background: #f8fafc;
                                    border-radius: 10px;
                                    border-width: 1px;
                                    border-color: #e2e8f0;

                                    LineEdit {
                                        x: 12px; y: 0px;
                                        width: parent.width - 24px;
                                        height: parent.height;
                                        placeholder-text: selected-connection-type == "Network" ? "IP address (e.g. 192.168.1.100)" : "Device path (e.g. COM3)";
                                        text <=> selected-device;
                                        enabled: !is-connected;
                                    }
                                }

                                Rectangle {
                                    width: 72px;
                                    height: 44px;
                                    background: (is-loading || is-connected) ? #f1f5f9 : #0f172a;
                                    border-radius: 10px;
                                    Text {
                                        text: is-loading ? "..." : "Scan";
                                        color: (is-loading || is-connected) ? #94a3b8 : white;
                                        font-size: 13px; font-weight: 600;
                                        horizontal-alignment: center; vertical-alignment: center;
                                    }
                                    TouchArea {
                                        mouse-cursor: (is-loading || is-connected) ? default : pointer;
                                        clicked => { if !is-loading && !is-connected { scan-devices(); } }
                                    }
                                }
                            }

                            // Device list
                            if available-devices.length > 0: VerticalBox {
                                spacing: 6px;
                                for device in available-devices: DeviceItem {
                                    visible: device-filter == "All" || device.type == selected-connection-type;
                                    path: device.path;
                                    description: device.description;
                                    device-type: device.type;
                                    selected: selected-device == device.path;
                                    clicked => { selected-device = device.path; }
                                }
                            }

                            // Connect / Disconnect
                            HorizontalBox {
                                spacing: 10px;
                                if !is-connected: PrimaryButton {
                                    label: "Connect Receipt Printer";
                                    disabled: selected-device == "";
                                    loading: is-loading;
                                    horizontal-stretch: 1;
                                    clicked => { connect-printer(selected-connection-type, selected-device); }
                                }
                                if is-connected: PrimaryButton {
                                    label: "Disconnect";
                                    bg: #dc2626;
                                    horizontal-stretch: 1;
                                    clicked => { disconnect-printer(); }
                                }
                            }

                            if status-message != "": Toast {
                                message: status-message;
                                type: toast-type;
                            }
                        }
                    }

                    // ── BARCODE PRINTER SECTION ──
                    Rectangle {
                        background: #fafafa;
                        border-radius: 16px;
                        border-width: 1px;
                        border-color: #e2e8f0;

                        VerticalBox {
                            padding: 24px;
                            spacing: 20px;

                            // Section header
                            HorizontalBox {
                                spacing: 10px;
                                alignment: start;

                                Rectangle {
                                    width: 32px;
                                    height: 32px;
                                    background: #1e3a5f;
                                    border-radius: 8px;
                                    Text {
                                        text: "📦";
                                        font-size: 16px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                VerticalBox {
                                    spacing: 0px;
                                    alignment: center;
                                    Text {
                                        text: "Barcode Printer";
                                        color: #0f172a;
                                        font-size: 16px;
                                        font-weight: 700;
                                    }
                                    Text {
                                        text: "TSPL / ZPL / EPL — Aokia AK-3001 & compatible";
                                        color: #94a3b8;
                                        font-size: 12px;
                                    }
                                }

                                Rectangle { horizontal-stretch: 1; }

                                StatusBadge {
                                    active: barcode-is-connected;
                                    label: barcode-is-connected ? "Online" : "Offline";
                                }
                            }

                            // Connection type
                            HorizontalBox {
                                spacing: 10px;

                                ConnectionCard {
                                    icon: "⌁"; label: "USB";
                                    selected: barcode-connection-type == "USB";
                                    disabled: barcode-is-connected;
                                    clicked => { barcode-connection-type = "USB"; }
                                }
                                ConnectionCard {
                                    icon: "◉"; label: "Network";
                                    selected: barcode-connection-type == "Network";
                                    disabled: barcode-is-connected;
                                    clicked => { barcode-connection-type = "Network"; }
                                }
                                ConnectionCard {
                                    icon: "▣"; label: "LPT";
                                    selected: barcode-connection-type == "LPT";
                                    disabled: barcode-is-connected;
                                    clicked => { barcode-connection-type = "LPT"; }
                                }
                            }

                            // Device input + scan
                            HorizontalBox {
                                spacing: 10px;

                                Rectangle {
                                    height: 44px;
                                    horizontal-stretch: 1;
                                    background: #f8fafc;
                                    border-radius: 10px;
                                    border-width: 1px;
                                    border-color: #e2e8f0;

                                    LineEdit {
                                        x: 12px; y: 0px;
                                        width: parent.width - 24px;
                                        height: parent.height;
                                        placeholder-text: barcode-connection-type == "Network" ? "IP:port (e.g. 192.168.1.101:9100)" : "Device path (e.g. COM5)";
                                        text <=> barcode-device;
                                        enabled: !barcode-is-connected;
                                    }
                                }

                                Rectangle {
                                    width: 72px;
                                    height: 44px;
                                    background: (barcode-is-loading || barcode-is-connected) ? #f1f5f9 : #0f172a;
                                    border-radius: 10px;
                                    Text {
                                        text: barcode-is-loading ? "..." : "Scan";
                                        color: (barcode-is-loading || barcode-is-connected) ? #94a3b8 : white;
                                        font-size: 13px; font-weight: 600;
                                        horizontal-alignment: center; vertical-alignment: center;
                                    }
                                    TouchArea {
                                        mouse-cursor: (barcode-is-loading || barcode-is-connected) ? default : pointer;
                                        clicked => { if !barcode-is-loading && !barcode-is-connected { scan-devices(); } }
                                    }
                                }
                            }

                            // Device list
                            if available-devices.length > 0: VerticalBox {
                                spacing: 6px;
                                for device in available-devices: DeviceItem {
                                    visible: device-filter == "All" || device.type == barcode-connection-type;
                                    path: device.path;
                                    description: device.description;
                                    device-type: device.type;
                                    selected: barcode-device == device.path;
                                    clicked => { barcode-device = device.path; }
                                }
                            }

                            // Protocol + Label settings row
                            HorizontalBox {
                                spacing: 12px;

                                // Protocol selector
                                VerticalBox {
                                    spacing: 4px;
                                    horizontal-stretch: 1.5;
                                    Text { text: "Protocol"; color: #94a3b8; font-size: 11px; font-weight: 600; }
                                    
                                    HorizontalBox {
                                        spacing: 6px;

                                        Rectangle {
                                            height: 40px;
                                            horizontal-stretch: 1;
                                            background: barcode-protocol == "TSPL" ? #0f172a : #ffffff;
                                            border-radius: 8px;
                                            border-width: 1px;
                                            border-color: barcode-protocol == "TSPL" ? #0f172a : #e2e8f0;
                                            Text {
                                                text: "TSPL";
                                                color: barcode-protocol == "TSPL" ? white : #64748b;
                                                font-size: 11px; font-weight: 600;
                                                horizontal-alignment: center; vertical-alignment: center;
                                            }
                                            TouchArea {
                                                mouse-cursor: barcode-is-connected ? default : pointer;
                                                clicked => { if !barcode-is-connected { barcode-protocol = "TSPL"; } }
                                            }
                                        }

                                        Rectangle {
                                            height: 40px;
                                            horizontal-stretch: 1;
                                            background: barcode-protocol == "ZPL" ? #0f172a : #ffffff;
                                            border-radius: 8px;
                                            border-width: 1px;
                                            border-color: barcode-protocol == "ZPL" ? #0f172a : #e2e8f0;
                                            Text {
                                                text: "ZPL";
                                                color: barcode-protocol == "ZPL" ? white : #64748b;
                                                font-size: 11px; font-weight: 600;
                                                horizontal-alignment: center; vertical-alignment: center;
                                            }
                                            TouchArea {
                                                mouse-cursor: barcode-is-connected ? default : pointer;
                                                clicked => { if !barcode-is-connected { barcode-protocol = "ZPL"; } }
                                            }
                                        }

                                        Rectangle {
                                            height: 40px;
                                            horizontal-stretch: 1;
                                            background: barcode-protocol == "EPL" ? #0f172a : #ffffff;
                                            border-radius: 8px;
                                            border-width: 1px;
                                            border-color: barcode-protocol == "EPL" ? #0f172a : #e2e8f0;
                                            Text {
                                                text: "EPL";
                                                color: barcode-protocol == "EPL" ? white : #64748b;
                                                font-size: 11px; font-weight: 600;
                                                horizontal-alignment: center; vertical-alignment: center;
                                            }
                                            TouchArea {
                                                mouse-cursor: barcode-is-connected ? default : pointer;
                                                clicked => { if !barcode-is-connected { barcode-protocol = "EPL"; } }
                                            }
                                        }
                                    }
                                }

                                VerticalBox {
                                    spacing: 4px;
                                    horizontal-stretch: 1;
                                    Text { text: "Width (mm)"; color: #94a3b8; font-size: 11px; font-weight: 600; }
                                    Rectangle {
                                        height: 40px;
                                        background: #f8fafc;
                                        border-radius: 8px;
                                        border-width: 1px;
                                        border-color: #e2e8f0;
                                        LineEdit {
                                            x: 10px; y: 0px;
                                            width: parent.width - 20px;
                                            height: parent.height;
                                            input-type: number;
                                            placeholder-text: "50";
                                            text: barcode-width-mm;
                                            enabled: !barcode-is-connected;
                                        }
                                    }
                                }

                                VerticalBox {
                                    spacing: 4px;
                                    horizontal-stretch: 1;
                                    Text { text: "Height (mm)"; color: #94a3b8; font-size: 11px; font-weight: 600; }
                                    Rectangle {
                                        height: 40px;
                                        background: #f8fafc;
                                        border-radius: 8px;
                                        border-width: 1px;
                                        border-color: #e2e8f0;
                                        LineEdit {
                                            x: 10px; y: 0px;
                                            width: parent.width - 20px;
                                            height: parent.height;
                                            input-type: number;
                                            placeholder-text: "30";
                                            text: barcode-height-mm;
                                            enabled: !barcode-is-connected;
                                        }
                                    }
                                }

                                VerticalBox {
                                    spacing: 4px;
                                    horizontal-stretch: 1;
                                    Text { text: "DPI"; color: #94a3b8; font-size: 11px; font-weight: 600; }
                                    Rectangle {
                                        height: 40px;
                                        background: #f8fafc;
                                        border-radius: 8px;
                                        border-width: 1px;
                                        border-color: #e2e8f0;
                                        LineEdit {
                                            x: 10px; y: 0px;
                                            width: parent.width - 20px;
                                            height: parent.height;
                                            input-type: number;
                                            placeholder-text: "203";
                                            text: barcode-dpi;
                                            enabled: !barcode-is-connected;
                                        }
                                    }
                                }
                            }

                            // Connect / Disconnect
                            HorizontalBox {
                                spacing: 10px;
                                if !barcode-is-connected: PrimaryButton {
                                    label: "Connect Barcode Printer";
                                    bg: #1e3a5f;
                                    disabled: barcode-device == "";
                                    loading: barcode-is-loading;
                                    horizontal-stretch: 1;
                                    clicked => {
                                        barcode-connect-printer(
                                            barcode-connection-type,
                                            barcode-device,
                                            barcode-protocol,
                                            barcode-width-mm,
                                            barcode-height-mm,
                                            barcode-dpi
                                        );
                                    }
                                }
                                if barcode-is-connected: PrimaryButton {
                                    label: "Disconnect";
                                    bg: #dc2626;
                                    horizontal-stretch: 1;
                                    clicked => { barcode-disconnect-printer(); }
                                }
                            }

                            if barcode-status-message != "": Toast {
                                message: barcode-status-message;
                                type: barcode-toast-type;
                            }
                        }
                    }

                    // Bottom spacer
                    Rectangle { vertical-stretch: 1; }
                }
            }
        }
    }
}
